---
import Layout from '../../layouts/Layout.astro';
import { fetchIndex, fetchDir, fetchPage } from '../../lib/data.js';
import markdown from '../../lib/markdown.js';
import matter from 'gray-matter';

export function getStaticPaths() {
  const { lists } = fetchIndex();
  const paths = [];
  for (const list of lists) {
    const volume = list.volume;
    const parent = fetchDir(volume);
    for (const page of parent.pages) {
      paths.push({
        params: { volume, chapter: page.chapter },
      });
    }
  }
  return paths;
}

const { volume, chapter } = Astro.params;

const text = fetchPage(volume, `${chapter}.md`);
const parent = fetchDir(volume);
const { title: volumeTitle, pages } = parent;
const i = pages.findIndex((e) => e.chapter === chapter);

const prev =
  i !== 0
    ? { title: pages[i - 1].title, chapter: pages[i - 1].chapter }
    : null;
const next =
  i !== pages.length - 1
    ? { title: pages[i + 1].title, chapter: pages[i + 1].chapter }
    : null;

const ma = matter(text);
const { title, author } = ma.data;
const wordCount = pages[i].wordCount;

const contentText = ma.content.replace(
  /!\[(.*)\]\(\/(.*)\)/g,
  '![$1](https://cdn.jsdelivr.net/gh/lzjluzijie/lgqm-tuku@main/$2)'
);
const html = markdown(contentText);

const prevHref = prev ? `/${volume}/${prev.chapter}` : `/${volume}/`;
const prevTitle = prev ? prev.title : volumeTitle;
const prevLabel = prev ? '上一章' : '返回目录';
const nextHref = next ? `/${volume}/${next.chapter}` : `/${volume}/`;
const nextTitle = next ? next.title : volumeTitle;
const nextLabel = next ? '下一章' : '返回目录';
const descriptionStr = contentText.slice(0, 150).replace(/\n/g, ' ') + '...';

---

<Layout title={`${title} - ${volumeTitle}`} description={descriptionStr}>
  <nav class="chapter-nav">
    <a class="nav-card" href={prevHref}>
      <span class="nav-label">{prevLabel}</span>
      <span class="nav-title">{prevTitle}</span>
    </a>
    <a class="nav-card" href={nextHref}>
      <span class="nav-label">{nextLabel}</span>
      <span class="nav-title">{nextTitle}</span>
    </a>
  </nav>

  <article class="post content mb-6">
    <h3 class="title has-text-centered">{title}</h3>
    <p class="subtitle has-text-centered" style="font-size: 0.95em;">
      <a href={`/${volume}/`}>{volumeTitle}</a>
      {` · ${author} · 约 ${wordCount} 字 · `}
      <a
        href={`https://github.com/lzjluzijie/lgqm-sjk/blob/main/content/${volume}/${chapter}.md`}
      >
        编辑本页
      </a>
    </p>
    <Fragment set:html={html} />
  </article>

  <nav class="chapter-nav">
    <a class="nav-card" href={prevHref}>
      <span class="nav-label">{prevLabel}</span>
      <span class="nav-title">{prevTitle}</span>
    </a>
    <a class="nav-card" href={nextHref}>
      <span class="nav-label">{nextLabel}</span>
      <span class="nav-title">{nextTitle}</span>
    </a>
  </nav>
</Layout>
