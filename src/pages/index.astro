---
import Layout from '../layouts/Layout.astro';
import { fetchIndex } from '../lib/data.js';
import markdown from '../lib/markdown.js';

const { lists } = fetchIndex();

const content = `
临高启明公开图书馆为爱好者建立的开源项目，目的是为临高启明读者提供修订过早期文本以及在线讨论环境。本站非官方，无版权，所有资料为论坛公开资料收集，请勿用于商业用途！如有侵权，请联系我们删除。

- Discord群：https://discord.gg/XgE4xJM
- 电报群：https://t.me/lingaoqiming
`;

const html = markdown(content);
---

<Layout title="主页">
  <article class="post content">
    <h1 class="title has-text-centered">欢迎来到：临高启明公开图书馆</h1>
    <Fragment set:html={html} />
    <h2 class="title has-text-centered" id="catalog">目录</h2>
    <p class="subtitle" style="font-size: 1.25em;">
      以下是已收录分卷列表，共 {lists.length} 卷
    </p>
    <div class="table-wrapper">
      <table class="table is-fullwidth table-auto">
        <thead>
          <tr>
            <th>编号</th>
            <th>标题</th>
            <th>作者</th>
            <th>文章数量</th>
          </tr>
        </thead>
        <tbody>
          {lists.map((list) => (
            <tr>
              <td>{list.volume}</td>
              <td>
                <a href={`/${list.volume}/`}>{list.title}</a>
              </td>
              <td>{list.author}</td>
              <td>{list.length}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </article>
</Layout>
